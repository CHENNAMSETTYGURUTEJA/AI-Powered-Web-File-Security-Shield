{
  "manifest_version": 3,
  "name": "Phishing Detector",
  "version": "1.0",
  "description": "Detect if the current tab is a phishing website.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "notifications",
    "webNavigation",
    "alarms",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  },
  "host_permissions": [
    "<all_urls>",
    "https://phishshield-api.onrender.com/*",
    "http://localhost:8000/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://ai-powered-web-file-security-shield.vercel.app/*"
      ],
      "js": ["status-sync.js"],
      "run_at": "document_idle"
    }
  ]
}
